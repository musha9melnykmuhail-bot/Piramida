                local coins = {}
                
                for _, v in ipairs(workspace:GetDescendants()) do
                    if v:IsA("Part") and v.Name:lower():find("coin") then
                        local dist = (v.Position - root.Position).Magnitude
                        if dist < settings.farmRadius then
                            table.insert(coins, v)
                        end
                    end
                end
                
                if #coins > 0 then
                    local closest = coins[1]
                    local closestDist = (closest.Position - root.Position).Magnitude
                    
                    for _, coin in ipairs(coins) do
                        local dist = (coin.Position - root.Position).Magnitude
                        if dist < closestDist then
                            closest = coin
                            closestDist = dist
                        end
                    end
                    
                    root.CFrame = closest.CFrame * CFrame.new(0, 2, 0)
                    task.wait(0.1)
                    
                    VirtualUser:ClickButton1(Vector2.new(), closest.CFrame)
