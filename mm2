-- ===== ASCII LOGO "PIRAMIDA" =====
local function ShowKsenoCMD()
    local KsenoCMD = loadstring(game:HttpGet("https://raw.githubusercontent.com/ksemenov/KsenoCMD/master/KsenoCMD.lua", true))()
    
    -- Очищаем консоль и показываем красивый ASCII-логотип
    KsenoCMD.Clear()
    
    -- Анимированное появление логотипа
    local logoLines = {
        " ",
        "██╗  ██╗███████╗███████╗███╗   ██╗ ██████╗     ██████╗ ███╗   ███╗██████╗ ",
        "██║ ██╔╝██╔════╝██╔════╝████╗  ██║██╔═══██╗   ██╔════╝ ████╗ ████║██╔══██╗",
        "█████╔╝ ███████╗███████╗██╔██╗ ██║██║   ██║   ██║  ███╗██╔████╔██║██║  ██║",
        "██╔═██╗ ╚════██║╚════██║██║╚██╗██║██║   ██║   ██║   ██║██║╚██╔╝██║██║  ██║",
        "██║  ██╗███████║███████║██║ ╚████║╚██████╔╝   ╚██████╔╝██║ ╚═╝ ██║██████╔╝",
        "╚═╝  ╚═╝╚══════╝╚══════╝╚═╝  ╚═══╝ ╚═════╝     ╚═════╝ ╚═╝     ╚═╝╚═════╝ ",
        " ",
        "═══════════════════════════════════════════════════════════════════════════",
        "                      MM2 ULTIMATE - PREMIUM SCRIPT                       ",
        "═══════════════════════════════════════════════════════════════════════════",
        " ",
        "✨ System initialized successfully!",
        "🔑 Key accepted: 2026-3",
        "👤 User: " .. game:GetService("Players").LocalPlayer.Name,
        "📅 Date: " .. os.date("%d.%m.%Y %H:%M:%S"),
        " ",
        "═══════════════════════════════════════════════════════════════════════════",
        "                     LOADING MAIN SCRIPT...                               ",
        "═══════════════════════════════════════════════════════════════════════════",
        " "
    }
    
    -- Анимированный вывод (построчно с задержкой)
    for i, line in ipairs(logoLines) do
        if line:match("═") or line:match("█") then
            -- Цветные линии
            KsenoCMD:print(line, "CYAN")
        elseif line:match("MM2") then
            KsenoCMD:print(line, "GREEN")
        elseif line:match("Key") or line:match("User") or line:match("Date") then
            KsenoCMD:print(line, "YELLOW")
        else
            KsenoCMD:print(line, "WHITE")
        end
        task.wait(0.03) -- Небольшая задержка для эффекта
    end
    
    -- Прогресс-бар загрузки
    KsenoCMD:print("LOADING: ", "CYAN", false)
    for i = 1, 30 do
        task.wait(0.02)
        KsenoCMD:print("█", "GREEN", false)
    end
    KsenoCMD:print(" 100%", "GREEN")
    task.wait(0.3)
    
    KsenoCMD:print(" ", "WHITE")
    KsenoCMD:print("✅ Script loaded! Press DELETE to toggle menu", "GREEN")
    KsenoCMD:print(" ", "WHITE")
    
    return KsenoCMD
end

