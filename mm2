--[[
    MM2 ULTIMATE PROTECTED
    Защита: MoonSec + Anti-Steal + HWID + Anti-Debug
]]

-- ===== СЛОЙ 1: ПРОВЕРКА НА ЭКЗЕКУТОР =====
local function checkExecutor()
    local allowed = false
    local executors = {"Xeno", "Synapse", "ScriptWare", "Krnl", "Electron"}
    
    -- Проверяем через identifyexecutor если есть
    local success, executorName = pcall(identifyexecutor)
    if success then
        for _, exe in ipairs(executors) do
            if executorName:find(exe) then
                allowed = true
                break
            end
        end
    end
    
    -- Альтернативная проверка
    if not allowed then
        -- Проверка на наличие функций характерных для экзекуторов
        if hookfunction or hookmetamethod or getcallingscript then
            allowed = true
        end
    end
    
    return allowed
end

-- ===== СЛОЙ 2: АНТИ-ДЕБАГГЕР =====
local function antiDebug()
    -- Убиваем дебаг функции
    if debug then
        for i, v in pairs(debug) do
            debug[i] = nil
        end
    end
    
    -- Проверка времени выполнения (против декомпиляторов)
    local startTime = os.clock()
    local dummy = ""
    for i = 1, 10000 do
        dummy = dummy .. tostring(math.random())
    end
    local execTime = os.clock() - startTime
    
    -- Если выполнилось слишком быстро - это декомпилятор
    if execTime < 0.1 then
        while true do end
    end
end

-- ===== СЛОЙ 3: HWID ПРОВЕРКА (ОПЦИОНАЛЬНО) =====
local function checkHWID()
    -- Сюда впиши свой HWID если хочешь
    local allowedHWIDs = {
        ["ваш_hwid_1"] = true,
        ["ваш_hwid_2"] = true,
    }
    
    local myHWID = game:GetService("RbxAnalyticsService"):GetClientId()
    return allowedHWIDs[myHWID] or true -- true = отключено
end

-- ===== СЛОЙ 4: ЗАЩИТА ОТ КОПИРОВАНИЯ ПАМЯТИ =====
local function memoryProtection()
    local protected = {}
    
    -- Прячем важные функции
    local oldLoadstring = loadstring
    loadstring = function(...)
        if not checkExecutor() then
            return error("Access denied")
        end
        return oldLoadstring(...)
    end
    
    -- Защищаем глобальные переменные
    getgenv().PROTECTED_MAIN = true
end

-- ===== СЛОЙ 5: ОСНОВНОЙ КОД С ОБФУСКАЦИЕЙ =====
local function mainScript()
    -- ТВОЙ ОСНОВНОЙ КОД (КОТОРЫЙ БЫЛ РАНЬШЕ)
    -- ВСТАВЛЯЕМ СЮДА ТОТ САМЫЙ ОБФУСЦИРОВАННЫЙ КОД
    -- КОТОРЫЙ ТЫ МНЕ СКИНУЛ
end

-- ===== ЗАПУСК С ЗАЩИТОЙ =====
pcall(function()
    -- Проверка 1: Экзекутор
    if not checkExecutor() then
        return -- Выходим если не тот софт
    end
    
    -- Проверка 2: Анти-дебаг
    antiDebug()
    
    -- Проверка 3: HWID
    if not checkHWID() then
        return
    end
    
    -- Проверка 4: Память
    memoryProtection()
    
    -- Запускаем основной код
    mainScript()
end)

-- ===== СЛОЙ 6: МИНА ДЛЯ ВОРОВ =====
-- Если кто-то пытается прочитать код через getfenv
local oldGetfenv = getfenv
getfenv = function(...)
    local result = oldGetfenv(...)
    if result and result.PROTECTED_MAIN then
        return {} -- Возвращаем пустоту
    end
    return result
end
